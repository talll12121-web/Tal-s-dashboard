# Copy this file to ".env" and edit. Locally, every value is optional - the app
# runs on free yfinance + RSS with SQLite and no login. The cloud-only vars are
# noted below.

# -- Web server (local) --
WEB_PORT=5000

# -- Database --
# Leave UNSET for local SQLite (data/dashboard.db).
# In the cloud, set to your Postgres connection string (Render fills this in
# automatically via render.yaml).
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# -- Login (set these before exposing the app on the internet) --
# If APP_PASSWORD is empty, the login gate is DISABLED (fine for local-only use).
APP_PASSWORD=
# Session signing key. Auto-generated if unset locally; set a fixed value in cloud.
SECRET_KEY=

# -- Desktop bridge shared secret --
# Set the SAME long random string here (server) and in bridge/.env (desktop).
BRIDGE_TOKEN=

# -- Interactive Brokers (LOCAL all-in-one mode only) --
# Set IB_ENABLED=true only when running the app on your trading PC and you want
# it to connect to IB Gateway directly. In the cloud, keep this false and run
# the desktop bridge instead.
IB_ENABLED=false
IB_HOST=127.0.0.1
# IB Gateway: live=4001, paper=4002 | TWS: live=7496, paper=7497
IB_PORT=4001
IB_CLIENT_ID=11

# -- Fundamentals fallback (matters in the cloud, where Yahoo blocks .info) --
# When yfinance is blocked from datacenter IPs, the Long-term tab falls back to,
# in order of preference: FMP > SEC EDGAR > Finnhub. Set whichever keys you have.
# FMP (preferred - full scorecard incl. P/E, P/B, market cap): financialmodelingprep.com
FMP_API_KEY=
# Finnhub (optional extra gap-fill): finnhub.io/register
FINNHUB_API_KEY=
# SEC EDGAR needs no key but requires a descripti